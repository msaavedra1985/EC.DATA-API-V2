{
  "name": "api-ec-esm",
  "version": "1.0.0",
  "description": "Enterprise API with ESM, Express, Sequelize, Redis, and comprehensive observability",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "lint": "eslint src/**/*.js tests/**/*.js",
    "lint:fix": "eslint src/**/*.js tests/**/*.js --fix",
    "db:dbml": "node src/db/utils/generateDbml.js",
    "db:setup": "node src/db/scripts/setup-fresh-db.js",
    "db:seed": "node src/db/seeders/run.js",
    "db:seed:core": "node src/db/seeders/core-seed.js",
    "db:seed:geo": "node src/db/seeders/run-geo.js",
    "db:migrate": "./node_modules/.bin/sequelize db:migrate --config src/config/database.cjs --migrations-path src/db/migrations",
    "db:migrate:undo": "./node_modules/.bin/sequelize db:migrate:undo --config src/config/database.cjs --migrations-path src/db/migrations",
    "db:migrate:undo:all": "./node_modules/.bin/sequelize db:migrate:undo:all --config src/config/database.cjs --migrations-path src/db/migrations",
    "db:migrate:status": "./node_modules/.bin/sequelize db:migrate:status --config src/config/database.cjs --migrations-path src/db/migrations",
    "db:migration:create": "./node_modules/.bin/sequelize migration:generate --name --migrations-path src/db/migrations"
  },
  "keywords": [
    "api",
    "express",
    "sequelize",
    "redis",
    "jwt",
    "esm"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@azure/storage-blob": "^12.28.0",
    "@types/node": "^22.13.11",
    "bcrypt": "^5.1.1",
    "cassandra-driver": "^4.8.0",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "country-state-city": "^3.2.1",
    "dayjs": "^1.11.19",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "i18n": "^0.15.2",
    "jsonwebtoken": "^9.0.2",
    "mqtt": "^5.15.0",
    "nanoid": "^5.1.6",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "pino": "^9.13.1",
    "pino-http": "^10.5.0",
    "pino-pretty": "^13.1.1",
    "prom-client": "^15.1.3",
    "redis": "^4.7.0",
    "sequelize": "^6.37.5",
    "sequelize-cli": "^6.6.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.19.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "eslint-plugin-import": "^2.31.0",
    "supertest": "^7.0.0",
    "vitest": "^2.1.8"
  }
}
